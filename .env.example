# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth Configuration (no real secret values in repo)
# Client ID: your-google-client-id.apps.googleusercontent.com
# Client Secret: your-google-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps Configuration
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Instagram Configuration
VITE_INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# ─── Gemini AI Configuration ──────────────────────────────────────────────────
# IMPORTANT: Use VITE_GEMINI_API_KEY — the server reads this on startup (never exposed to browser)
VITE_GEMINI_API_KEY=your-gemini-api-key
# Optional: Port for Express API server (default: 3001)
API_PORT=3001
